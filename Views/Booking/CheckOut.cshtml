@model HotelProject.Models.ViewModel.CheckOutViewModel;
@{
    Layout = "/Views/Shared/_PrintLayout.cshtml";
}
  <script>
        $(document).ready(function () {
            $("#Print").click(function () {
                $("#Print").hide();
                $("#backButton").hide();
                window.print();
                $("#Print").show();
                $("#backButton").show();
            });
        });
        </script>        
<table>
    <tr>
        <td width="50%">
            <img src="~/images/logo.png" style="width:100%;" />
        </td>
        <td>
            <table>
                <tr>
                    <td style="padding-left:20px;">
                        <label style="font-weight:bold;font-size:20px;" >
                            @Model.HotelDetails.Name
                        </label>   <br />
                        <label>
                            @Model.HotelDetails.Address1
                        </label> <br />
                        <label>
                            @Model.HotelDetails.Address2
                        </label>
                        <label>
                            @Model.HotelDetails.City,
                        </label>
                        <label>
                            @Model.HotelDetails.State,
                        </label>
                        <label>
                            @Model.HotelDetails.PinCode
                        </label><br />
                        <label>
                            @Model.HotelDetails.MobileNumber1
                        </label><br />
                        <label>
                            @Model.HotelDetails.GSTNumber
                        </label><br />
                        <label>@Model.HotelDetails.Website</label>
                    </td>
                </tr>
            </table>
        </td>
    </tr>
    <tr>
        <td colspan="2" style="text-align:right;">
             <hr /><br />
            <label>@DateTime.Now.ToString("dd-MMM-yyyy hh:mm tt")</label>    
            <br />
        </td>
    </tr>
    <tr>
        <td colspan="2" style="text-align:center;">
             
            <label style="font-weight:bold;">Booking Number : PPC/@Model.BookingID</label>            
            <br />
        </td>
    </tr>
    <tr>
        <td colspan="2">
           
            <label style="font-weight:bold;">Billed To :</label><br />
            <label>@Model.CustomerDetails.FirstName </label>
            <label>@Model.CustomerDetails.LastName</label><br />
            <label>@Model.CustomerDetails.Address1 </label><br />
            <label>@Model.CustomerDetails.Address2</label><br />
            <label>@Model.CustomerDetails.City</label> <label>@Model.CustomerDetails.State</label><br />
            <label>@Model.CustomerDetails.PinCode</label><br />
            <label>@Model.CustomerDetails.PhoneNumber</label><br />
            @if (!string.IsNullOrEmpty(Model.CustomerDetails.AadharCardNumber))
            {
                @string.Concat("AadharCard Number - ", Model.CustomerDetails.AadharCardNumber+", ")
            }
            @if (!string.IsNullOrEmpty(Model.CustomerDetails.PanCardNumber))
            {
                @string.Concat("PanCard Number - ", Model.CustomerDetails.PanCardNumber+", ")
            }
            @if (!string.IsNullOrEmpty(Model.CustomerDetails.PassportNumber))
            {
                @string.Concat("Passport Number - ", Model.CustomerDetails.PassportNumber+", ")
            }
            @if (!string.IsNullOrEmpty(Model.CustomerDetails.DrivingLicenseNumber))
            {
                @string.Concat("Driving License Number - ", Model.CustomerDetails.DrivingLicenseNumber+", ")
            }
            @if (!string.IsNullOrEmpty(Model.CustomerDetails.Others))
            {
                @string.Concat("Others - ", Model.CustomerDetails.Others+", ")
            }
            <br />
            @if (!string.IsNullOrEmpty(Model.CustomerDetails.GST))
            {
                @string.Concat("GST - ", Model.CustomerDetails.GST)
            }
        </td>
    </tr>
    <tr>
        <td colspan="2">
            <br />
            @if (Model != null && Model.RoomDetails != null && Model.RoomDetails.Rows.Count > 0)
            {
                <table class="table table-bordered">
                    <thead>
                        <tr>
                            <th>Room</th>
                            <th>CheckIn Date</th>
                            <th>CheckOut Date</th>
                            <th>No Of Days</th>
                            <th>Extra Bed</th>
                            <th>Room Charges</th>
                            <th>Extra Bed Charges</th>
                            <th>Total</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (System.Data.DataRow row in Model.RoomDetails.Rows)
                        {
                            <tr>
                                @* @foreach (var item in row.ItemArray)
                                { *@
                                <td>@row["RoomName"]</td>
                                <td>@if(!string.IsNullOrEmpty(row["CheckInDate"].ToString())) { @row["CheckInDate"] }</td>
                                <td>@if(!string.IsNullOrEmpty(row["CheckOutDate"].ToString())) { @row["CheckOutDate"] }</td>
                                <td>@if(!string.IsNullOrEmpty(row["NoOfDays"].ToString())) { @row["NoOfDays"] }</td>
                                <td>@if(!string.IsNullOrEmpty(row["ExtraBeds"].ToString())) { @row["ExtraBeds"] }</td>
                                <td>@if(!string.IsNullOrEmpty(row["RoomCharge"].ToString())) { @row["RoomCharge"] }</td>
                                <td>@if(!string.IsNullOrEmpty(row["ExtraBedCharge"].ToString())) { @row["ExtraBedCharge"] }</td>
                                <td>@if(!string.IsNullOrEmpty(row["TotalAmount"].ToString())) { @row["TotalAmount"] }</td>
                                @* } *@
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </td>
    </tr>
    <tr>
        <td colspan="2" style="text-align:left;">
            <label style="font-weight:bold;">Amount In Words</label><br/>
            <label>@Model.AmountInWords</label>
        </td>
    <tr>
        <td></td>
    <td style="text-align:right;">
        <br />
        <br />
        <br />
        <br />
        <label> Authorised Signatory</label>
    </td>
    </tr>
    <tr>
    <td>
        <a class="btn btn-primary" id="backButton" asp-controller="Booking" asp-action="Edit" name="action" asp-route-id="@Model.BookingID">Back</a>
        <a class="btn btn-primary" id="Print" name="action">Print</a>
    </td>
        <td></td>
    </tr>
</table>

  